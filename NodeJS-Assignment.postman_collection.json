{
  "info": {
    "name": "NodeJS Assignment API",
    "description": "Postman collection for Person Information Assignment APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "personId", "value": "" },
    { "key": "changeRequestId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (Access User)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"accessuser1\",\n  \"email\": \"accessuser1@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}",
                  "if (json.user && json.user.userId) {",
                  "  pm.collectionVariables.set('userId', json.user.userId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@12345\",\n  \"loginForm\": \"web\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Roles (Admin)",
      "item": [
        {
          "name": "Create Role",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleName\": \"Operator\",\n  \"description\": \"Operator role\"\n}"
            },
            "url": "{{baseUrl}}/api/roles"
          }
        },
        {
          "name": "List Roles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/roles"
          }
        }
      ]
    },
    {
      "name": "Users (Admin)",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"operator1\",\n  \"email\": \"operator1@example.com\",\n  \"password\": \"Password@123\",\n  \"roleName\": \"Operator\"\n}"
            },
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        }
      ]
    },
    {
      "name": "Persons",
      "item": [
        {
          "name": "Submit Create Person (Admin/Operator)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.changeRequestId) {",
                  "  pm.collectionVariables.set('changeRequestId', json.changeRequestId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Asha\",\n  \"middleName\": \"Rao\",\n  \"lastName\": \"Kulkarni\",\n  \"gender\": \"Female\",\n  \"dateOfBirth\": \"1990-05-12\",\n  \"age\": 35,\n  \"address\": {\n    \"flatNumber\": \"A-101\",\n    \"societyName\": \"Sunshine Apartments\",\n    \"streetOrArea\": \"MG Road\"\n  },\n  \"city\": \"Pune\",\n  \"state\": \"Maharashtra\",\n  \"pinCode\": \"411001\",\n  \"phoneNo\": \"02012345678\",\n  \"mobileNo\": \"9876543210\",\n  \"physicalDisability\": \"\",\n  \"maritalStatus\": \"Married\",\n  \"educationStatus\": \"Masters\",\n  \"birthSign\": \"Taurus\"\n}"
            },
            "url": "{{baseUrl}}/api/persons"
          }
        },
        {
          "name": "Submit Update Person (pending approval)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.changeRequestId) {",
                  "  pm.collectionVariables.set('changeRequestId', json.changeRequestId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"city\": \"Mumbai\",\n  \"state\": \"Maharashtra\"\n}"
            },
            "url": "{{baseUrl}}/api/persons/{{personId}}"
          }
        },
        {
          "name": "Get Person By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/persons/{{personId}}"
          }
        }
      ]
    },
    {
      "name": "Change Requests (Admin)",
      "item": [
        {
          "name": "List Change Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/change-requests"
          }
        },
        {
          "name": "List Pending Change Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/change-requests?status=pending"
          }
        },
        {
          "name": "Approve Change Request",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.person && json.person.personId) {",
                  "  pm.collectionVariables.set('personId', json.person.personId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/change-requests/{{changeRequestId}}/approve"
          }
        },
        {
          "name": "Reject Change Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Invalid or incomplete data\"\n}"
            },
            "url": "{{baseUrl}}/api/change-requests/{{changeRequestId}}/reject"
          }
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Search by Name",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/persons/search?PersonName=Asha"
          }
        },
        {
          "name": "Search by City",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/persons/search?City=Pune"
          }
        },
        {
          "name": "Search by Age Range",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/persons/search?AgeGt=30&AgeLt=60"
          }
        },
        {
          "name": "Search by Combined Filters",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/persons/search?Gender=Female&City=Pune&PinCode=411001"
          }
        },
        {
          "name": "Search with Pagination",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/persons/search?limit=10&skip=0"
          }
        }
      ]
    }
  ]
}
